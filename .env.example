# ============================================
# EdilEngine - Environment Variables
# Copia questo file in .env e compila con i valori reali
# ============================================

# ------------------------------------------
# Database PostgreSQL + pgvector
# ------------------------------------------
DATABASE_URL=postgresql+asyncpg://edilengine:edilengine_dev@localhost:5432/edilengine
DATABASE_URL_SYNC=postgresql://edilengine:edilengine_dev@localhost:5432/edilengine

# ------------------------------------------
# LLM Provider per chatbot (qualsiasi provider OpenAI-compatible)
# ------------------------------------------
# API key del provider scelto
OPENAI_API_KEY=sk-your-api-key-here

# Base URL del provider (scegli UNO):
#   OpenAI:       https://api.openai.com/v1
#   DeepSeek:     https://api.deepseek.com
#   OpenRouter:   https://openrouter.ai/api/v1
#   Groq:         https://api.groq.com/openai/v1
#   Together:     https://api.together.ai/v1
#   Mistral:      https://api.mistral.ai/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Modello per chat (scegli in base al provider):
#   OpenAI:       gpt-4o, gpt-4o-mini
#   DeepSeek:     deepseek-chat, deepseek-reasoner
#   OpenRouter:   meta-llama/llama-3.1-8b-instruct, google/gemma-2-9b-it, ecc.
#   Groq:         llama-3.1-8b-instant, llama-3.1-70b-versatile, mixtral-8x7b-32768
#   Together:     meta-llama/Llama-3.1-8B-Instruct-Turbo, mistralai/Mixtral-8x7B-Instruct-v0.1
#   Mistral:      mistral-large-latest, open-mistral-nemo
OPENAI_CHAT_MODEL=gpt-4o

# ------------------------------------------
# Embedding Provider (GRATUITO con modelli locali!)
# ------------------------------------------
# "local" = sentence-transformers, GRATUITO, funziona offline
# "openai" = API OpenAI, a pagamento, qualità superiore
EMBEDDING_PROVIDER=local

# Nome modello locale (usato solo se EMBEDDING_PROVIDER=local)
# paraphrase-multilingual-MiniLM-L12-v2 = 384 dim, veloce, buono per italiano (consigliato)
# intfloat/multilingual-e5-small = 384 dim, migliore per retrieval
# intfloat/multilingual-e5-base = 768 dim, qualità alta, più pesante
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# Dimensione vettore embeddings (DEVE corrispondere al modello scelto)
# 384 per i modelli locali sopra, 1536 per OpenAI text-embedding-3-small
EMBEDDING_DIMENSION=384

# Modello embeddings OpenAI (usato solo se EMBEDDING_PROVIDER=openai)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Base URL per embeddings OpenAI (usato solo se EMBEDDING_PROVIDER=openai)
OPENAI_EMBEDDING_BASE_URL=

# ------------------------------------------
# CORS
# ------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ------------------------------------------
# Frontend (Next.js)
# ------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080

# ------------------------------------------
# Backend (FastAPI)
# ------------------------------------------
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# ------------------------------------------
# Scraper
# ------------------------------------------
NORMATTIVA_BASE_URL=https://www.normattiva.it
GAZZETTA_UFFICIALE_URL=https://www.gazzettaufficiale.it

# ------------------------------------------
# Rate Limiting
# ------------------------------------------
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60